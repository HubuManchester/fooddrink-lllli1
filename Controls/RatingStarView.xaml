<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodLens.Controls.RatingStarView"
             x:Name="This">

    <HorizontalStackLayout Spacing="2" VerticalOptions="Center"
                            SemanticProperties.Description="{Binding Source={x:Reference This}, Path=Rating, StringFormat='Rating: {0} out of 5'}">
        <Image Source="star_filled.png"
               WidthRequest="20" HeightRequest="20"
               IsVisible="{Binding Source={x:Reference This}, Path=Star1Visible}" />
        <Image Source="star_filled.png"
               WidthRequest="20" HeightRequest="20"
               IsVisible="{Binding Source={x:Reference This}, Path=Star2Visible}" />
        <Image Source="star_filled.png"
               WidthRequest="20" HeightRequest="20"
               IsVisible="{Binding Source={x:Reference This}, Path=Star3Visible}" />
        <Image Source="star_filled.png"
               WidthRequest="20" HeightRequest="20"
               IsVisible="{Binding Source={x:Reference This}, Path=Star4Visible}" />
        <Image Source="star_filled.png"
               WidthRequest="20" HeightRequest="20"
               IsVisible="{Binding Source={x:Reference This}, Path=Star5Visible}" />
    </HorizontalStackLayout>

</ContentView>
