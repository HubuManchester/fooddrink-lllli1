<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodLens.Controls.CategoryChipView"
             x:Name="This">

    <Frame Padding="0"
           CornerRadius="16"
           BackgroundColor="{Binding Source={x:Reference This}, Path=ChipColor}"
           BorderColor="Transparent"
           HasShadow="True"
           MinimumHeightRequest="44"
           AutomationId="CategoryChip"
           SemanticProperties.Description="{Binding Source={x:Reference This}, Path=CategoryName}"
           SemanticProperties.Hint="Tap to browse recipes in this category">
        <Frame.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding Source={x:Reference This}, Path=TapCommand}"
                                  CommandParameter="{Binding Source={x:Reference This}, Path=CategoryName}" />
        </Frame.GestureRecognizers>
        <VerticalStackLayout Spacing="6"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Padding="12,10">
            <Label Text="{Binding Source={x:Reference This}, Path=ChipIcon}"
                   FontSize="28"
                   TextColor="White"
                   HorizontalOptions="Center" />
            <Label Text="{Binding Source={x:Reference This}, Path=CategoryName}"
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>
    </Frame>

</ContentView>
