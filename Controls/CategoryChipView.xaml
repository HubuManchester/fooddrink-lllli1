<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodLens.Controls.CategoryChipView"
             x:Name="This">

    <Frame Padding="12,8"
           CornerRadius="20"
           BackgroundColor="{Binding Source={x:Reference This}, Path=ChipColor}"
           BorderColor="Transparent"
           HasShadow="False"
           HeightRequest="40">
        <Frame.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding Source={x:Reference This}, Path=TapCommand}"
                                  CommandParameter="{Binding Source={x:Reference This}, Path=CategoryName}" />
        </Frame.GestureRecognizers>
        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
            <Label Text="{Binding Source={x:Reference This}, Path=ChipIcon}"
                   FontSize="14"
                   TextColor="White"
                   VerticalOptions="Center" />
            <Label Text="{Binding Source={x:Reference This}, Path=CategoryName}"
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>
    </Frame>

</ContentView>
