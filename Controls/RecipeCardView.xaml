<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodLens.Models"
             x:Class="FoodLens.Controls.RecipeCardView"
             x:Name="This">

    <Frame Style="{StaticResource CardFrame}"
           Margin="4,6"
           Padding="0"
           IsClippedToBounds="True"
           AutomationId="RecipeCard"
           SemanticProperties.Description="{Binding Source={x:Reference This}, Path=RecipeTitle}"
           SemanticProperties.Hint="Tap to view recipe details">
        <Frame.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding Source={x:Reference This}, Path=TapCommand}"
                                  CommandParameter="{Binding Source={x:Reference This}, Path=RecipeId}" />
        </Frame.GestureRecognizers>

        <Grid ColumnDefinitions="2*,3*" HeightRequest="160" IsClippedToBounds="True">

            <Grid Grid.Column="0" IsClippedToBounds="True">
                <Grid IsVisible="{Binding Source={x:Reference This}, Path=ImageUrl, Converter={StaticResource StringEmptyConverter}}">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource PrimaryLight}" Offset="0" />
                            <GradientStop Color="{StaticResource Primary}" Offset="1" />
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Label Text="&#x1F373;"
                           FontSize="32"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Opacity="0.6" />
                </Grid>

                <Image Source="{Binding Source={x:Reference This}, Path=ImageUrl}"
                       Aspect="AspectFill"
                       IsVisible="{Binding Source={x:Reference This}, Path=ImageUrl, Converter={StaticResource StringNotEmptyConverter}}"
                       SemanticProperties.Description="Recipe thumbnail" />
            </Grid>

            <VerticalStackLayout Grid.Column="1" Padding="12,10,12,10" Spacing="4" VerticalOptions="Fill">
                <Label Text="{Binding Source={x:Reference This}, Path=RecipeTitle}"
                       Style="{StaticResource LabelLarge}"
                       FontSize="15"
                       LineBreakMode="TailTruncation"
                       MaxLines="2"
                       VerticalOptions="Start" />

                <Label Text="{Binding Source={x:Reference This}, Path=RecipeDescription}"
                       Style="{StaticResource LabelBody}"
                       LineBreakMode="TailTruncation"
                       MaxLines="2"
                       FontSize="12"
                       VerticalOptions="Start" />

                <Grid ColumnDefinitions="Auto,Auto,Auto" VerticalOptions="End" Margin="0,4,0,0" HorizontalOptions="Fill">
                    <HorizontalStackLayout Grid.Column="0" Spacing="3">
                        <Label Text="&#x1F552;" FontSize="10" VerticalOptions="Center" />
                        <Label Text="{Binding Source={x:Reference This}, Path=CookTime, StringFormat='{0} min'}"
                               Style="{StaticResource LabelSmall}" FontSize="11" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Label Grid.Column="1" Text="{Binding Source={x:Reference This}, Path=Difficulty}"
                           Style="{StaticResource LabelSmall}" FontSize="11" VerticalOptions="Center" Margin="8,0,0,0" />

                    <Label Grid.Column="2" Text="{Binding Source={x:Reference This}, Path=Calories, StringFormat='{0} cal'}"
                           Style="{StaticResource LabelSmall}" FontSize="11" VerticalOptions="Center" Margin="8,0,0,0" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto" VerticalOptions="End">
                    <Frame Grid.Column="0" CornerRadius="8"
                           BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                           BorderColor="Transparent"
                           Padding="6,2"
                           HasShadow="False"
                           HeightRequest="22"
                           HorizontalOptions="Start"
                           IsVisible="{Binding Source={x:Reference This}, Path=Category, Converter={StaticResource StringNotEmptyConverter}}">
                        <Label Text="{Binding Source={x:Reference This}, Path=Category}"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="White" />
                    </Frame>

                    <Image Grid.Column="1" Source="{Binding Source={x:Reference This}, Path=FavoriteIcon}"
                           WidthRequest="22" HeightRequest="22"
                           MinimumWidthRequest="44" MinimumHeightRequest="44"
                           HorizontalOptions="End"
                           VerticalOptions="Center"
                           SemanticProperties.Description="Toggle favorite">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:Reference This}, Path=FavoriteCommand}"
                                                  CommandParameter="{Binding Source={x:Reference This}, Path=RecipeId}" />
                        </Image.GestureRecognizers>
                    </Image>
                </Grid>
            </VerticalStackLayout>
        </Grid>
    </Frame>

</ContentView>
