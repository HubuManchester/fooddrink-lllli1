<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FoodLens.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FoodLens.Views"
    Title="FoodLens"
    FlyoutBehavior="Flyout">

    <Shell.FlyoutHeader>
        <VerticalStackLayout Padding="24,32,24,20"
                             BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
            <Label Text="FoodLens"
                   FontSize="32" FontAttributes="Bold"
                   FontFamily="OpenSansSemibold"
                   TextColor="White"
                   HorizontalOptions="Center" />
            <Label Text="Smart Recipe &amp; Meal Planner"
                   FontSize="13"
                   TextColor="#FFE0CC"
                   HorizontalOptions="Center"
                   Margin="0,6,0,0" />
        </VerticalStackLayout>
    </Shell.FlyoutHeader>

    <Shell.FlyoutFooter>
        <VerticalStackLayout Padding="16" Spacing="4">
            <Label Text="FoodLens v1.0"
                   FontSize="11"
                   TextColor="{AppThemeBinding Light={StaticResource TextHint}, Dark={StaticResource Gray500}}"
                   HorizontalOptions="Center" />
            <Label Text="Built with .NET MAUI"
                   FontSize="10"
                   TextColor="{AppThemeBinding Light={StaticResource TextHint}, Dark={StaticResource Gray500}}"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>
    </Shell.FlyoutFooter>

    <FlyoutItem Title="Home" Icon="home.png">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate views:HomePage}" Route="home" Title="Home" />
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="Categories" Icon="category.png">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate views:CategoryListPage}" Route="categories" Title="Categories" />
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="Search" Icon="search.png">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate views:SearchPage}" Route="search" Title="Search" />
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="Favorites" Icon="favorites.png">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate views:FavoritesPage}" Route="favorites" Title="Favorites" />
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="Meal Plan" Icon="calendar.png">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate views:MealPlanPage}" Route="mealplan" Title="Meal Plan" />
        </Tab>
    </FlyoutItem>

    <ShellContent Route="recipedetail"
                  ContentTemplate="{DataTemplate views:RecipeDetailPage}"
                  Title="Recipe Detail" />

    <ShellContent Route="register"
                  ContentTemplate="{DataTemplate views:RegisterPage}"
                  Title="Register" />

    <FlyoutItem Title="Settings" Icon="settings.png">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}" Route="settings" Title="Settings" />
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="Login" Icon="login.png">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate views:LoginPage}" Route="login" Title="Login" />
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="About" Icon="about.png">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate views:AboutPage}" Route="about" Title="About" />
        </Tab>
    </FlyoutItem>

</Shell>
