<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodLens.Views.SplashPage"
             BackgroundColor="#512BD4">

    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="20">
        <Label Text="FoodLens"
               FontSize="48"
               FontAttributes="Bold"
               TextColor="White"
               HorizontalOptions="Center" />
        <Label Text="Smart Recipe &amp; Meal Planner"
               FontSize="18"
               TextColor="#E0E0E0"
               HorizontalOptions="Center" />
        <ActivityIndicator IsRunning="True" Color="White" Margin="0,20,0,0" />
    </VerticalStackLayout>

</ContentPage>
