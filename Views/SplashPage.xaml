<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodLens.Views.SplashPage"
             BackgroundColor="{StaticResource Primary}"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False">

    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
        <Label Text="FoodLens"
               FontSize="48"
               FontAttributes="Bold"
               FontFamily="OpenSansSemibold"
               TextColor="White"
               HorizontalOptions="Center" />

        <Label Text="Smart Recipe &amp; Meal Planner"
               FontSize="16"
               FontFamily="OpenSansRegular"
               TextColor="#FFE0CC"
               HorizontalOptions="Center" />

        <BoxView HeightRequest="1" WidthRequest="80"
                 BackgroundColor="#FFFFFF40"
                 HorizontalOptions="Center"
                 Margin="0,16,0,0" />

        <ActivityIndicator IsRunning="True" Color="White" Margin="0,20,0,0"
                           WidthRequest="32" HeightRequest="32"
                           HorizontalOptions="Center" />

        <Label Text="Loading delicious recipes..."
               FontSize="12"
               TextColor="#FFFFFFCC"
               HorizontalOptions="Center"
               Margin="0,8,0,0" />
    </VerticalStackLayout>

</ContentPage>
