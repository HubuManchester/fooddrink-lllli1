<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodLens.Views.SettingsPage"
             Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PaddingPage}" Spacing="{StaticResource SpacingMedium}">

            <Label Text="Settings"
                   Style="{StaticResource LabelSectionHeader}"
                   SemanticProperties.HeadingLevel="Level1" />

            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="20">
                    <Label Text="Appearance"
                           Style="{StaticResource LabelLarge}"
                           SemanticProperties.HeadingLevel="Level2" />

                    <HorizontalStackLayout Spacing="16" VerticalOptions="Center">
                        <Label Text="Dark Mode"
                               Style="{StaticResource LabelMedium}"
                               VerticalOptions="Center"
                               HorizontalOptions="FillAndExpand" />
                        <Switch x:Name="DarkModeSwitch"
                                AutomationId="DarkModeSwitch"
                                SemanticProperties.Description="Toggle dark mode"
                                SemanticProperties.Hint="Switch between light and dark theme" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="About"
                           Style="{StaticResource LabelLarge}"
                           SemanticProperties.HeadingLevel="Level2" />
                    <Label Text="FoodLens v1.0" Style="{StaticResource LabelBody}" />
                    <Label Text="Smart Recipe &amp; Meal Planner" Style="{StaticResource LabelCaption}" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
