<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodLens.ViewModels"
             x:Class="FoodLens.Views.RecipeDetailPage"
             x:DataType="vm:RecipeDetailViewModel"
             Title="{Binding Recipe.Title}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            <Label Text="{Binding Recipe.Title}"
                   FontSize="24" FontAttributes="Bold"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label Text="{Binding Recipe.Description}"
                   FontSize="16" LineBreakMode="WordWrap" />

            <HorizontalStackLayout Spacing="16" Margin="0,8,0,0">
                <VerticalStackLayout>
                    <Label Text="Prep Time" FontSize="12" TextColor="Gray" />
                    <Label Text="{Binding Recipe.PrepTimeMinutes, StringFormat='{0} min'}" FontSize="16" />
                </VerticalStackLayout>
                <VerticalStackLayout>
                    <Label Text="Cook Time" FontSize="12" TextColor="Gray" />
                    <Label Text="{Binding Recipe.CookTimeMinutes, StringFormat='{0} min'}" FontSize="16" />
                </VerticalStackLayout>
                <VerticalStackLayout>
                    <Label Text="Servings" FontSize="12" TextColor="Gray" />
                    <Label Text="{Binding Recipe.Servings}" FontSize="16" />
                </VerticalStackLayout>
                <VerticalStackLayout>
                    <Label Text="Calories" FontSize="12" TextColor="Gray" />
                    <Label Text="{Binding Recipe.Calories, StringFormat='{0} cal'}" FontSize="16" />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <Label Text="Ingredients"
                   FontSize="20" FontAttributes="Bold"
                   SemanticProperties.HeadingLevel="Level2"
                   Margin="0,16,0,0" />

            <CollectionView ItemsSource="{Binding Recipe.Ingredients}"
                            SemanticProperties.Description="Ingredients list">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding Name}" FontSize="14" Margin="0,4" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Instructions"
                   FontSize="20" FontAttributes="Bold"
                   SemanticProperties.HeadingLevel="Level2"
                   Margin="0,16,0,0" />

            <CollectionView ItemsSource="{Binding Recipe.Instructions}"
                            SemanticProperties.Description="Cooking instructions">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label FontSize="14" Margin="0,4">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding .}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <HorizontalStackLayout Spacing="16" Margin="0,16,0,0">
                <Button Text="Favorite"
                        Command="{Binding ToggleFavoriteCommand}"
                        SemanticProperties.Hint="Add or remove this recipe from favorites" />
                <Button Text="Read Steps"
                        Command="{Binding ReadStepsCommand}"
                        SemanticProperties.Hint="Read cooking steps aloud using text to speech" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
