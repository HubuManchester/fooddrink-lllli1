<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodLens.ViewModels"
             xmlns:models="clr-namespace:FoodLens.Models"
             xmlns:controls="clr-namespace:FoodLens.Controls"
             x:Class="FoodLens.Views.SearchPage"
             x:DataType="vm:SearchViewModel"
             Title="Search">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <VerticalStackLayout Grid.Row="0" Padding="{StaticResource PaddingPage}" Spacing="{StaticResource SpacingSmall}">
            <SearchBar Placeholder="Search recipes..."
                       Text="{Binding SearchKeyword}"
                       AutomationId="SearchBar"
                       SemanticProperties.Description="Search recipes by keyword"
                       SemanticProperties.Hint="Enter a recipe name or ingredient to search"
                       />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1" Orientation="Horizontal" Margin="16,0">
            <HorizontalStackLayout Spacing="8">
                <Button Text="All" Command="{Binding FilterByCategoryCommand}" CommandParameter=""
                         Style="{StaticResource ButtonChip}"
                         AutomationId="FilterAll"
                         SemanticProperties.Hint="Show all recipes" />
                <Button Text="Breakfast" Command="{Binding FilterByCategoryCommand}" CommandParameter="Breakfast"
                         Style="{StaticResource ButtonChip}"
                         AutomationId="FilterBreakfast"
                         SemanticProperties.Hint="Filter by breakfast" />
                <Button Text="Lunch" Command="{Binding FilterByCategoryCommand}" CommandParameter="Lunch"
                         Style="{StaticResource ButtonChip}"
                         AutomationId="FilterLunch"
                         SemanticProperties.Hint="Filter by lunch" />
                <Button Text="Dinner" Command="{Binding FilterByCategoryCommand}" CommandParameter="Dinner"
                         Style="{StaticResource ButtonChip}"
                         AutomationId="FilterDinner"
                         SemanticProperties.Hint="Filter by dinner" />
                <Button Text="Dessert" Command="{Binding FilterByCategoryCommand}" CommandParameter="Dessert"
                         Style="{StaticResource ButtonChip}"
                         AutomationId="FilterDessert"
                         SemanticProperties.Hint="Filter by dessert" />
                <Button Text="Drinks" Command="{Binding FilterByCategoryCommand}" CommandParameter="Drinks"
                         Style="{StaticResource ButtonChip}"
                         AutomationId="FilterDrinks"
                         SemanticProperties.Hint="Filter by drinks" />
            </HorizontalStackLayout>
        </ScrollView>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding SearchResults}"
                        Margin="16,0"
                        AutomationId="SearchResultsList"
                        SemanticProperties.Description="Search results">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Recipe">
                    <controls:RecipeCardView
                        RecipeId="{Binding Id}"
                        RecipeTitle="{Binding Title}"
                        RecipeDescription="{Binding Description}"
                        CookTime="{Binding CookTimeMinutes}"
                        Difficulty="{Binding Difficulty}"
                        Calories="{Binding Calories}"
                        Category="{Binding Category}"
                        IsFavorite="{Binding IsFavorite}"
                        ImageUrl="{Binding ImageUrl}"
                        TapCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=NavigateToRecipeCommand}"
                        FavoriteCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=ToggleFavoriteCommand}" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="2"
               Text="No recipes found. Try a different search."
               IsVisible="{Binding IsEmpty}"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Style="{StaticResource LabelBody}"
               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource Gray300}}"
               SemanticProperties.Description="No search results found" />

        <ActivityIndicator Grid.Row="3"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           AutomationId="SearchActivityIndicator"
                           SemanticProperties.Description="Searching recipes"
                           HorizontalOptions="Center"
                           Margin="0,8" />
    </Grid>

</ContentPage>
