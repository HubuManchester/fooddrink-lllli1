<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodLens.ViewModels"
             x:Class="FoodLens.Views.RecipeEditPage"
             x:DataType="vm:RecipeEditViewModel"
             Title="{Binding ViewModelTitle}">

    <Grid RowDefinitions="*,Auto,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="{StaticResource PaddingPage}" Spacing="{StaticResource SpacingMedium}">

                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="&#x1F4CB; Recipe Details"
                               Style="{StaticResource LabelSectionHeader}"
                               SemanticProperties.HeadingLevel="Level1" />

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Title *" Style="{StaticResource LabelCaption}" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Entry Grid.Column="0" Text="{Binding Title}"
                                       Placeholder="Enter recipe title"
                                       AutomationId="RecipeTitleEntry"
                                       SemanticProperties.Hint="Recipe title" />
                                <Button Grid.Column="1" Text="&#x1F3A4;"
                                        Command="{Binding StartSpeechCommand}" CommandParameter="title"
                                        WidthRequest="48" HeightRequest="48"
                                        CornerRadius="24" FontSize="22"
                                        Padding="0"
                                        MinimumWidthRequest="44"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                        TextColor="White"
                                        IsEnabled="{Binding IsListening, Converter={StaticResource BoolToInverseConverter}}"
                                        SemanticProperties.Hint="Voice input for title"
                                        AutomationId="MicTitleButton" />
                            </Grid>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Description *" Style="{StaticResource LabelCaption}" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Editor Grid.Column="0" Text="{Binding Description}"
                                        Placeholder="Describe your recipe"
                                        HeightRequest="80"
                                        AutomationId="RecipeDescriptionEntry"
                                        SemanticProperties.Hint="Recipe description" />
                                <Button Grid.Column="1" Text="&#x1F3A4;"
                                        Command="{Binding StartSpeechCommand}" CommandParameter="description"
                                        WidthRequest="48" HeightRequest="48"
                                        CornerRadius="24" FontSize="22"
                                        Padding="0"
                                        MinimumWidthRequest="44"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                        TextColor="White"
                                        IsEnabled="{Binding IsListening, Converter={StaticResource BoolToInverseConverter}}"
                                        SemanticProperties.Hint="Voice input for description"
                                        AutomationId="MicDescriptionButton" />
                            </Grid>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Category" Style="{StaticResource LabelCaption}" />
                                <Picker ItemsSource="{Binding CategoryOptions}"
                                        SelectedItem="{Binding Category}"
                                        Title="Select category"
                                        AutomationId="RecipeCategoryPicker"
                                        SemanticProperties.Hint="Recipe category" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Difficulty" Style="{StaticResource LabelCaption}" />
                                <Picker ItemsSource="{Binding DifficultyOptions}"
                                        SelectedItem="{Binding Difficulty}"
                                        Title="Select difficulty"
                                        AutomationId="RecipeDifficultyPicker"
                                        SemanticProperties.Hint="Recipe difficulty" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Cook Time (min)" Style="{StaticResource LabelCaption}" />
                                <Entry Text="{Binding CookTimeMinutesText}"
                                       Placeholder="20"
                                       Keyboard="Numeric"
                                       AutomationId="RecipeCookTimeEntry"
                                       SemanticProperties.Hint="Cooking time in minutes" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Calories" Style="{StaticResource LabelCaption}" />
                                <Entry Text="{Binding CaloriesText}"
                                       Placeholder="300"
                                       Keyboard="Numeric"
                                       AutomationId="RecipeCaloriesEntry"
                                       SemanticProperties.Hint="Calorie count" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="4">
                                <Label Text="Servings" Style="{StaticResource LabelCaption}" />
                                <Entry Text="{Binding ServingsText}"
                                       Placeholder="2"
                                       Keyboard="Numeric"
                                       AutomationId="RecipeServingsEntry"
                                       SemanticProperties.Hint="Number of servings" />
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Image URL" Style="{StaticResource LabelCaption}" />
                            <Entry Text="{Binding ImageUrl}"
                                   Placeholder="https://example.com/image.jpg"
                                   Keyboard="Url"
                                   AutomationId="RecipeImageUrlEntry"
                                   SemanticProperties.Hint="Image URL for recipe photo" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="&#x1F957; Ingredients"
                               Style="{StaticResource LabelSectionHeader}"
                               SemanticProperties.HeadingLevel="Level2" />

                        <CollectionView ItemsSource="{Binding Ingredients}"
                                        AutomationId="IngredientsEditList"
                                        SemanticProperties.Description="Ingredients list">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:IngredientItem">
                                    <Frame Padding="10,8"
                                           Margin="0,4"
                                           CornerRadius="12"
                                           BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A3E}"
                                           BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A4E}"
                                           HasShadow="False">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12"
                                              VerticalOptions="Center">
                                            <HorizontalStackLayout Grid.Column="0" Spacing="8"
                                                                   VerticalOptions="Center">
                                                <Label Text="{Binding Name}"
                                                       Style="{StaticResource LabelMedium}"
                                                       FontAttributes="Bold"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding Quantity}"
                                                       Style="{StaticResource LabelSmall}"
                                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}" />
                                                <Label Text="{Binding Unit}"
                                                       Style="{StaticResource LabelSmall}"
                                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource Gray400}}" />
                                            </HorizontalStackLayout>
                                            <ImageButton Grid.Column="1"
                                                         Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipeEditViewModel}}, Path=RemoveIngredientCommand}"
                                                         CommandParameter="{Binding .}"
                                                         WidthRequest="30"
                                                         HeightRequest="30"
                                                         BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#3E2A2A}"
                                                         CornerRadius="15"
                                                         SemanticProperties.Hint="Remove ingredient">
                                                <ImageButton.Source>
                                                    <FontImageSource Glyph="&#x00D7;"
                                                                    FontFamily="OpenSansSemibold"
                                                                    Size="16"
                                                                    Color="#F44336" />
                                                </ImageButton.Source>
                                            </ImageButton>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Frame Padding="10"
                               CornerRadius="12"
                               BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#2E2A1E}"
                               BorderColor="{AppThemeBinding Light=#FFE0B2, Dark=#4A3E2E}"
                               HasShadow="False">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="6">
                                <Entry Grid.Column="0" Text="{Binding NewIngredientName}"
                                       Placeholder="Ingredient"
                                       FontSize="14"
                                       SemanticProperties.Hint="New ingredient name" />
                                <Entry Grid.Column="1" Text="{Binding NewIngredientQuantity}"
                                       Placeholder="Qty" WidthRequest="55"
                                       FontSize="14"
                                       Keyboard="Numeric"
                                       SemanticProperties.Hint="Quantity" />
                                <Entry Grid.Column="2" Text="{Binding NewIngredientUnit}"
                                       Placeholder="Unit" WidthRequest="55"
                                       FontSize="14"
                                       SemanticProperties.Hint="Unit of measurement" />
                                <Button Grid.Column="3" Text="&#x1F3A4;"
                                        Command="{Binding StartSpeechCommand}" CommandParameter="ingredient"
                                        WidthRequest="36" HeightRequest="36"
                                        CornerRadius="18" FontSize="14"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                        TextColor="White" Padding="0"
                                        IsEnabled="{Binding IsListening, Converter={StaticResource BoolToInverseConverter}}"
                                        SemanticProperties.Hint="Voice input for ingredient name"
                                        AutomationId="MicIngredientButton" />
                                 <ImageButton Grid.Column="4"
                                              Command="{Binding AddIngredientCommand}"
                                              WidthRequest="36"
                                              HeightRequest="36"
                                              BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                              CornerRadius="18"
                                              SemanticProperties.Hint="Add ingredient">
                                     <ImageButton.Source>
                                         <FontImageSource Glyph="+"
                                                         FontFamily="OpenSansSemibold"
                                                         Size="20"
                                                         Color="White" />
                                     </ImageButton.Source>
                                 </ImageButton>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="&#x1F4DD; Instructions"
                               Style="{StaticResource LabelSectionHeader}"
                               SemanticProperties.HeadingLevel="Level2" />

                        <CollectionView ItemsSource="{Binding Instructions}"
                                        AutomationId="InstructionsEditList"
                                        SemanticProperties.Description="Cooking instructions">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Frame Padding="10,8"
                                           Margin="0,4"
                                           CornerRadius="12"
                                           BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A3E}"
                                           BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A4E}"
                                           HasShadow="False">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"
                                              VerticalOptions="Center">
                                            <Label Grid.Column="0" Text="{Binding .}"
                                                   Style="{StaticResource LabelMedium}"
                                                   LineBreakMode="WordWrap" />
                                            <ImageButton Grid.Column="1"
                                                         Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipeEditViewModel}}, Path=RemoveInstructionCommand}"
                                                         CommandParameter="{Binding .}"
                                                         WidthRequest="30"
                                                         HeightRequest="30"
                                                         BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#3E2A2A}"
                                                         CornerRadius="15"
                                                         SemanticProperties.Hint="Remove instruction step">
                                                <ImageButton.Source>
                                                    <FontImageSource Glyph="&#x00D7;"
                                                                    FontFamily="OpenSansSemibold"
                                                                    Size="16"
                                                                    Color="#F44336" />
                                                </ImageButton.Source>
                                            </ImageButton>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Frame Padding="10"
                               CornerRadius="12"
                               BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#2E2A1E}"
                               BorderColor="{AppThemeBinding Light=#FFE0B2, Dark=#4A3E2E}"
                               HasShadow="False">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <Entry Grid.Column="0" Text="{Binding NewInstruction}"
                                       Placeholder="Add a cooking step..."
                                       FontSize="14"
                                       ReturnCommand="{Binding AddInstructionCommand}"
                                       SemanticProperties.Hint="New instruction step" />
                                <Button Grid.Column="1" Text="&#x1F3A4;"
                                        Command="{Binding StartSpeechCommand}" CommandParameter="instruction"
                                        WidthRequest="36" HeightRequest="36"
                                        CornerRadius="18" FontSize="14"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                        TextColor="White" Padding="0"
                                        IsEnabled="{Binding IsListening, Converter={StaticResource BoolToInverseConverter}}"
                                        SemanticProperties.Hint="Voice input for instruction"
                                        AutomationId="MicInstructionButton" />
                                <ImageButton Grid.Column="2"
                                             Command="{Binding AddInstructionCommand}"
                                             WidthRequest="36"
                                             HeightRequest="36"
                                             BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                             CornerRadius="18"
                                             SemanticProperties.Hint="Add instruction step">
                                    <ImageButton.Source>
                                        <FontImageSource Glyph="+"
                                                        FontFamily="OpenSansSemibold"
                                                        Size="20"
                                                        Color="White" />
                                    </ImageButton.Source>
                                </ImageButton>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <BoxView HeightRequest="16" BackgroundColor="Transparent" />

            </VerticalStackLayout>
        </ScrollView>

        <Frame Grid.Row="1"
               IsVisible="{Binding HasError}"
               BackgroundColor="#33F44336"
               BorderColor="{StaticResource Danger}"
               Padding="16"
               Margin="16,0">
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource Danger}"
                   Style="{StaticResource LabelBody}"
                   LineBreakMode="WordWrap" />
        </Frame>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,*"
              Padding="{StaticResource PaddingPage}"
              ColumnSpacing="{StaticResource SpacingMedium}">
            <Button Grid.Column="0" Text="&#x1F4BE; Save Recipe"
                    Command="{Binding SaveRecipeCommand}"
                    Style="{StaticResource ButtonSecondary}"
                    AutomationId="SaveRecipeButton"
                    SemanticProperties.Hint="Save this recipe"
                    FontSize="15" />
            <Button Grid.Column="1" Text="&#x1F5D1;&#xFE0F; Delete"
                    Command="{Binding DeleteRecipeCommand}"
                    IsVisible="{Binding IsEditMode}"
                    BackgroundColor="{StaticResource Danger}"
                    TextColor="White"
                    AutomationId="DeleteRecipeButton"
                    SemanticProperties.Hint="Delete this recipe permanently"
                    FontSize="15" />
        </Grid>

        <ActivityIndicator Grid.Row="0"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           SemanticProperties.Description="Saving recipe" />
    </Grid>

</ContentPage>
