<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodLens.ViewModels"
             x:Class="FoodLens.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="Login"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="24" VerticalOptions="Center">

            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="FoodLens"
                       Style="{StaticResource LabelDisplay}"
                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}"
                       HorizontalOptions="Center"
                       SemanticProperties.HeadingLevel="Level1" />

                <Label Text="Sign in to your account"
                       Style="{StaticResource LabelBody}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Frame Style="{StaticResource CardFrame}" Margin="0,8,0,0">
                <VerticalStackLayout Spacing="16">
                    <Entry Placeholder="Email"
                           Keyboard="Email"
                           Text="{Binding Email}"
                           AutomationId="LoginEmailEntry"
                           SemanticProperties.Description="Email address"
                           SemanticProperties.Hint="Enter your email address" />

                    <Entry Placeholder="Password"
                           IsPassword="True"
                           Text="{Binding Password}"
                           AutomationId="LoginPasswordEntry"
                           SemanticProperties.Description="Password"
                           SemanticProperties.Hint="Enter your password" />

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Danger}"
                           FontSize="12"
                           IsVisible="{Binding HasError}"
                           AutomationId="LoginErrorMessage"
                           SemanticProperties.Description="Login error message" />

                    <Button Text="Login"
                            Command="{Binding LoginCommand}"
                            AutomationId="LoginButton"
                            SemanticProperties.Hint="Sign in to your account" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Don't have an account? Register"
                   HorizontalOptions="Center"
                   Style="{StaticResource LabelMedium}"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
