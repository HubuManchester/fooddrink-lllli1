<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodLens.ViewModels"
             x:Class="FoodLens.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="Login"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" HeightRequest="180" VerticalOptions="Start">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{StaticResource Primary}" Offset="0" />
                    <GradientStop Color="{StaticResource PrimaryLight}" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                <Label Text="&#x1F373;"
                       FontSize="40"
                       HorizontalOptions="Center" />
                <Label Text="FoodLens"
                       FontSize="32"
                       FontAttributes="Bold"
                       FontFamily="OpenSansSemibold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       SemanticProperties.HeadingLevel="Level1" />
                <Label Text="Sign in to your account"
                       FontSize="14"
                       TextColor="#FFE0CC"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1" Margin="0,-30,0,0">
            <VerticalStackLayout Padding="32,0,32,32" Spacing="20" VerticalOptions="Start">

                <Frame Style="{StaticResource CardFrame}"
                       Margin="0,0,0,8"
                       Padding="20">
                    <VerticalStackLayout Spacing="16">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Email" Style="{StaticResource LabelCaption}" />
                            <Entry Placeholder="Enter your email"
                                   Keyboard="Email"
                                   Text="{Binding Email}"
                                   AutomationId="LoginEmailEntry"
                                   SemanticProperties.Description="Email address"
                                   SemanticProperties.Hint="Enter your email address" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Password" Style="{StaticResource LabelCaption}" />
                            <Entry Placeholder="Enter your password"
                                   IsPassword="True"
                                   Text="{Binding Password}"
                                   AutomationId="LoginPasswordEntry"
                                   SemanticProperties.Description="Password"
                                   SemanticProperties.Hint="Enter your password" />
                        </VerticalStackLayout>

                        <Label Text="{Binding ErrorMessage}"
                               TextColor="{StaticResource Danger}"
                               FontSize="12"
                               IsVisible="{Binding HasError}"
                               AutomationId="LoginErrorMessage"
                               SemanticProperties.Description="Login error message" />

                        <Button Text="Sign In"
                                Command="{Binding LoginCommand}"
                                AutomationId="LoginButton"
                                SemanticProperties.Hint="Sign in to your account"
                                FontSize="16"
                                HeightRequest="52" />
                    </VerticalStackLayout>
                </Frame>

                <Label Text="Don't have an account? Register"
                       HorizontalOptions="Center"
                       Style="{StaticResource LabelMedium}"
                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
