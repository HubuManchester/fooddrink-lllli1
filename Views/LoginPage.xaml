<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodLens.ViewModels"
             x:Class="FoodLens.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="Login">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">
            <Label Text="FoodLens"
                   FontSize="36" FontAttributes="Bold"
                   HorizontalOptions="Center"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label Text="Sign in to your account"
                   FontSize="16" TextColor="Gray"
                   HorizontalOptions="Center" />

            <Entry Placeholder="Email"
                   Keyboard="Email"
                   Text="{Binding Email}"
                   SemanticProperties.Description="Email address"
                   SemanticProperties.Hint="Enter your email address" />

            <Entry Placeholder="Password"
                   IsPassword="True"
                   Text="{Binding Password}"
                   SemanticProperties.Description="Password"
                   SemanticProperties.Hint="Enter your password" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red" FontSize="12"
                   IsVisible="{Binding HasError}"
                   SemanticProperties.Description="Login error message" />

            <Button Text="Login"
                    Command="{Binding LoginCommand}"
                    SemanticProperties.Hint="Sign in to your account" />

            <Label Text="Don't have an account? Register"
                   HorizontalOptions="Center" TextColor="#512BD4">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                </Label.GestureRecognizers>
            </Label>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
