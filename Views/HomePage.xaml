<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodLens.ViewModels"
             x:Class="FoodLens.Views.HomePage"
             x:DataType="vm:HomePageViewModel"
             Title="FoodLens">

    <RefreshView Command="{Binding LoadRecipesCommand}" IsRefreshing="{Binding IsRefreshing}">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="16">
                <Label Text="Welcome to FoodLens!"
                       Style="{StaticResource Headline}"
                       SemanticProperties.HeadingLevel="Level1" />

                <Label Text="Discover delicious recipes"
                       Style="{StaticResource SubHeadline}"
                       SemanticProperties.HeadingLevel="Level2" />

                <CollectionView ItemsSource="{Binding FeaturedRecipes}"
                                SemanticProperties.Description="Featured recipes list">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,8" Padding="12" CornerRadius="12"
                                   SemanticProperties.Description="{Binding Title}">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding Title}"
                                           FontSize="18" FontAttributes="Bold" />
                                    <Label Text="{Binding Description}"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2" />
                                    <HorizontalStackLayout Spacing="12">
                                        <Label Text="{Binding CookTimeMinutes, StringFormat='{0} min'}"
                                               FontSize="12" TextColor="Gray" />
                                        <Label Text="{Binding Difficulty}"
                                               FontSize="12" TextColor="Gray" />
                                        <Label Text="{Binding Calories, StringFormat='{0} cal'}"
                                               FontSize="12" TextColor="Gray" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   SemanticProperties.Description="Loading recipes" />
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
