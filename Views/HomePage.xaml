<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodLens.ViewModels"
             xmlns:models="clr-namespace:FoodLens.Models"
             xmlns:controls="clr-namespace:FoodLens.Controls"
             x:Class="FoodLens.Views.HomePage"
             x:DataType="vm:HomePageViewModel"
             Title="FoodLens">

    <RefreshView Command="{Binding LoadRecipesCommand}" IsRefreshing="{Binding IsRefreshing}">
        <ScrollView>
            <VerticalStackLayout Padding="{StaticResource PaddingPage}" Spacing="{StaticResource SpacingLarge}">

                <VerticalStackLayout Spacing="4" Margin="0,0,0,8">
                    <Label Text="Welcome to FoodLens!"
                           Style="{StaticResource LabelHeadline}"
                           HorizontalOptions="Start" />
                    <Label Text="Discover delicious recipes for every meal"
                           Style="{StaticResource LabelBody}"
                           HorizontalOptions="Start" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource SpacingSmall}">
                    <Label Text="Featured Recipes"
                           Style="{StaticResource LabelSectionHeader}" />

                    <CollectionView ItemsSource="{Binding FeaturedRecipes}"
                                    SemanticProperties.Description="Featured recipes list">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Recipe">
                                <controls:RecipeCardView
                                    RecipeId="{Binding Id}"
                                    RecipeTitle="{Binding Title}"
                                    RecipeDescription="{Binding Description}"
                                    CookTime="{Binding CookTimeMinutes}"
                                    Difficulty="{Binding Difficulty}"
                                    Calories="{Binding Calories}"
                                    Category="{Binding Category}"
                                    IsFavorite="{Binding IsFavorite}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   SemanticProperties.Description="Loading recipes"
                                   HorizontalOptions="Center" />

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
