<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodLens.ViewModels"
             x:Class="FoodLens.Views.MealPlanPage"
             x:DataType="vm:MealPlanViewModel"
             Title="Meal Plan">

    <VerticalStackLayout Padding="16" Spacing="16">
        <Label Text="Meal Planner"
               FontSize="24" FontAttributes="Bold"
               SemanticProperties.HeadingLevel="Level1" />

        <DatePicker Date="{Binding SelectedDate}"
                   SemanticProperties.Description="Select a date for meal planning"
                   SemanticProperties.Hint="Choose the date you want to plan meals for" />

        <CollectionView ItemsSource="{Binding MealPlans}"
                        SemanticProperties.Description="Meals planned for selected date">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,4" Padding="12" CornerRadius="8">
                        <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                            <Label Text="{Binding MealType}" FontSize="14" FontAttributes="Bold" WidthRequest="80" />
                            <Label Text="{Binding Recipe.Title}" FontSize="14" />
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Text="No meals planned for this date."
               IsVisible="{Binding IsEmpty}"
               HorizontalOptions="Center" TextColor="Gray"
               SemanticProperties.Description="No meals planned" />
    </VerticalStackLayout>

</ContentPage>
