<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodLens.ViewModels"
             x:Class="FoodLens.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title="Register"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="24" VerticalOptions="Center">

            <Label Text="Create Account"
                   Style="{StaticResource LabelTitle}"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}" />

            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="16">
                    <Entry Placeholder="Display Name"
                           Text="{Binding DisplayName}"
                           SemanticProperties.Description="Display name"
                           SemanticProperties.Hint="Enter your display name" />

                    <Entry Placeholder="Email"
                           Keyboard="Email"
                           Text="{Binding Email}"
                           SemanticProperties.Description="Email address"
                           SemanticProperties.Hint="Enter your email address" />

                    <Entry Placeholder="Password"
                           IsPassword="True"
                           Text="{Binding Password}"
                           SemanticProperties.Description="Password"
                           SemanticProperties.Hint="Enter a password (minimum 6 characters)" />

                    <Entry Placeholder="Confirm Password"
                           IsPassword="True"
                           Text="{Binding ConfirmPassword}"
                           SemanticProperties.Description="Confirm password"
                           SemanticProperties.Hint="Re-enter your password to confirm" />

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Danger}"
                           FontSize="12"
                           IsVisible="{Binding HasError}"
                           SemanticProperties.Description="Registration error message" />

                    <Button Text="Register"
                            Command="{Binding RegisterCommand}"
                            SemanticProperties.Hint="Create your account" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Already have an account? Login"
                   HorizontalOptions="Center"
                   Style="{StaticResource LabelMedium}"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
