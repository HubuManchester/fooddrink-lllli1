<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodLens.ViewModels"
             x:Class="FoodLens.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title="Register"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" HeightRequest="140" VerticalOptions="Start">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{StaticResource Secondary}" Offset="0" />
                    <GradientStop Color="{StaticResource SecondaryLight}" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                <Label Text="&#x1F64C;"
                       FontSize="36"
                       HorizontalOptions="Center" />
                <Label Text="Create Account"
                       FontSize="28"
                       FontAttributes="Bold"
                       FontFamily="OpenSansSemibold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       SemanticProperties.HeadingLevel="Level1" />
                <Label Text="Join FoodLens today"
                       FontSize="14"
                       TextColor="#C8E6C9"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1" Margin="0,-30,0,0">
            <VerticalStackLayout Padding="32,0,32,32" Spacing="20" VerticalOptions="Start">

                <Frame Style="{StaticResource CardFrame}"
                       Padding="20">
                    <VerticalStackLayout Spacing="16">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Display Name" Style="{StaticResource LabelCaption}" />
                            <Entry Placeholder="Enter your name"
                                   Text="{Binding DisplayName}"
                                   AutomationId="RegisterDisplayNameEntry"
                                   SemanticProperties.Description="Display name"
                                   SemanticProperties.Hint="Enter your display name" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Email" Style="{StaticResource LabelCaption}" />
                            <Entry Placeholder="Enter your email"
                                   Keyboard="Email"
                                   Text="{Binding Email}"
                                   AutomationId="RegisterEmailEntry"
                                   SemanticProperties.Description="Email address"
                                   SemanticProperties.Hint="Enter your email address" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Password" Style="{StaticResource LabelCaption}" />
                            <Entry Placeholder="Create a password"
                                   IsPassword="True"
                                   Text="{Binding Password}"
                                   AutomationId="RegisterPasswordEntry"
                                   SemanticProperties.Description="Password"
                                   SemanticProperties.Hint="Enter a password (minimum 6 characters)" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Confirm Password" Style="{StaticResource LabelCaption}" />
                            <Entry Placeholder="Confirm your password"
                                   IsPassword="True"
                                   Text="{Binding ConfirmPassword}"
                                   AutomationId="RegisterConfirmPasswordEntry"
                                   SemanticProperties.Description="Confirm password"
                                   SemanticProperties.Hint="Re-enter your password to confirm" />
                        </VerticalStackLayout>

                        <Label Text="{Binding ErrorMessage}"
                               TextColor="{StaticResource Danger}"
                               FontSize="12"
                               IsVisible="{Binding HasError}"
                               AutomationId="RegisterErrorMessage"
                               SemanticProperties.Description="Registration error message" />

                        <Button Text="Create Account"
                                Command="{Binding RegisterCommand}"
                                AutomationId="RegisterButton"
                                SemanticProperties.Hint="Create your account"
                                FontSize="16"
                                HeightRequest="52" />
                    </VerticalStackLayout>
                </Frame>

                <Label Text="Already have an account? Login"
                       HorizontalOptions="Center"
                       Style="{StaticResource LabelMedium}"
                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
